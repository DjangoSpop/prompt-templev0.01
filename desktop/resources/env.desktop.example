# Copy to .env.desktop and fill in values. The packaged app reads these
# and injects them into the forked Next.js standalone server's env at startup.
#
# IMPORTANT: .env.desktop is bundled into the installer via electron-builder
# `extraResources`. Do NOT commit it to git. .gitignore already excludes it.

ZAI_AUTH_TOKEN=
ZAI_BASE_URL=https://api.z.ai/api/anthropic
ZAI_MODEL=glm-4.7

# Generated on first launch and persisted in electron-store if not set here.
# Setting it here gives you stable session cookies across reinstalls.
NEXTAUTH_SECRET=

# Backend the renderer talks to (matches the web build's prod default).
NEXT_PUBLIC_API_BASE_URL=https://api.prompt-temple.com
NEXT_PUBLIC_BACKEND_URL=https://api.prompt-temple.com
NEXT_PUBLIC_WS_URL=wss://api.prompt-temple.com
NEXT_PUBLIC_APP_ENVIRONMENT=production
